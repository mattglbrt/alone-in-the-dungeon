---
import { Image } from 'astro:assets';
import type { Post } from '../utils/collections';
import {
  TYPE_LABELS,
  STORY_KIND_LABELS,
  FORMAT_LABELS,
  GAME_TYPE_LABELS,
  formatDate,
  postUrl,
} from '../utils/collections';

interface Props {
  post: Post;
  eager?: boolean;
}
const { post, eager = false } = Astro.props;
const { data } = post;
const isVideo = data.format === 'video';
const typeLabel = data.storyKind ? STORY_KIND_LABELS[data.storyKind] : TYPE_LABELS[data.type];
const youtubeThumbnail =
  isVideo && data.youtubeId ? `https://i.ytimg.com/vi/${data.youtubeId}/hqdefault.jpg` : null;
---

<a href={postUrl(post)} class="rune-card group flex h-full flex-col overflow-hidden no-underline">
  {data.heroImage ? (
    <div class="relative overflow-hidden">
      <Image
        src={data.heroImage}
        alt={data.heroImageAlt ?? data.title}
        loading={eager ? 'eager' : 'lazy'}
        widths={[480, 720, 960]}
        sizes="(min-width: 1024px) 32vw, (min-width: 768px) 46vw, 92vw"
        class="aspect-[5/3] w-full object-cover transition duration-500 group-hover:scale-[1.03]"
      />
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-void-950/70 to-transparent"></div>
      {isVideo && (
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-void-950/70 text-glow-50">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
        </div>
      )}
    </div>
  ) : youtubeThumbnail ? (
    <div class="relative overflow-hidden">
      <img
        src={youtubeThumbnail}
        alt={data.title}
        loading={eager ? 'eager' : 'lazy'}
        class="aspect-[5/3] w-full object-cover transition duration-500 group-hover:scale-[1.03]"
      />
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-void-950/70 to-transparent"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-void-950/70 text-glow-50">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </div>
      </div>
    </div>
  ) : (
    <div class="flex aspect-[5/3] w-full items-center justify-center bg-void-800/60 px-6 text-center">
      {isVideo && (
        <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-full border border-violet-500/50 text-violet-300">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </div>
      )}
      <span class="font-pixel text-lg text-violet-300/80">{data.title}</span>
    </div>
  )}

  <div class="flex flex-1 flex-col p-5">
    <div class="mb-3 flex flex-wrap items-center gap-2 font-sans text-[0.62rem] uppercase tracking-[0.2em]">
      <span class="rounded-full border border-violet-600/50 px-2 py-0.5 text-violet-300">
        {typeLabel}
      </span>
      {data.gameType && (
        <span class="text-mist-500">{GAME_TYPE_LABELS[data.gameType]}</span>
      )}
      {isVideo && (
        <span class="text-azure-400/80">{FORMAT_LABELS[data.format]}</span>
      )}
      {data.episode != null && (
        <span class="text-mist-500">Ep. {data.episode}</span>
      )}
    </div>

    <h3 class="font-pixel text-xl text-glow-50 transition group-hover:text-violet-300">
      {data.title}
    </h3>

    {data.system && (
      <p class="mt-1 font-sans text-xs uppercase tracking-[0.14em] text-azure-400/80">
        {data.system}
      </p>
    )}

    <p class="mt-3 flex-1 font-reading text-sm leading-relaxed text-glow-200/85 line-clamp-3">
      {data.description}
    </p>

    <p class="mt-4 font-sans text-[0.65rem] uppercase tracking-[0.2em] text-mist-600">
      {formatDate(data.date)}
    </p>
  </div>
</a>

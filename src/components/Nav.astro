---
const links = [
  { href: '/live-plays/', label: 'Live Plays', duration: '5.9s', delay: '-1.2s' },
  { href: '/stories/', label: 'Stories', duration: '5.1s', delay: '-2.8s' },
  {
    href: '/blog/',
    label: 'Blog',
    duration: '5.5s',
    delay: '-4.1s',
    children: [
      { href: '/reviews/', label: 'Reviews' },
      { href: '/guides/', label: 'Guides' },
      { href: '/news/', label: 'News' },
      { href: '/hobby/', label: 'Hobby' },
    ],
  },
  {
    href: '/contact/',
    label: 'Contact',
    duration: '5.7s',
    delay: '-3.9s',
    children: [{ href: '/about/', label: 'About' }],
  },
];
---

<header class="relative z-20 border-b border-void-700/80 bg-void-950/70 backdrop-blur-sm">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a
      href="/"
      class="witchlight font-pixel text-xl tracking-[0.08em] text-glow-50 no-underline hover:text-violet-300"
    >
      Alone in the Dungeon
    </a>

    <nav class="hidden md:block" aria-label="Primary">
      <ul class="flex items-center gap-6 font-pixel text-sm tracking-[0.06em] text-glow-100">
        {links.map((l) => (
          <li class={l.children ? 'group relative' : undefined}>
            <a
              href={l.href}
              class="witchlight no-underline transition hover:text-violet-300"
              style={`animation-duration: ${l.duration}; animation-delay: ${l.delay};`}
            >
              {l.label}
            </a>
            {l.children && (
              <ul
                class="invisible absolute left-1/2 top-full z-30 -translate-x-1/2 pt-3 opacity-0 transition duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
              >
                <li class="flex flex-col gap-1 rounded-lg border border-void-700/80 bg-void-900/95 p-2 shadow-lg shadow-void-950/60 backdrop-blur-sm">
                  {l.children.map((c) => (
                    <a
                      href={c.href}
                      class="whitespace-nowrap rounded px-3 py-2 text-sm text-glow-100 no-underline transition hover:bg-violet-500/10 hover:text-violet-300"
                    >
                      {c.label}
                    </a>
                  ))}
                </li>
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <button
      type="button"
      class="md:hidden inline-flex h-11 w-11 items-center justify-center rounded border border-void-700 text-glow-100"
      aria-label="Toggle menu"
      aria-expanded="false"
      data-nav-toggle
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </button>
  </div>

  <nav
    class="md:hidden hidden border-t border-void-700/80 bg-void-900"
    aria-label="Mobile"
    data-nav-menu
  >
    <ul class="mx-auto flex max-w-6xl flex-col px-6 py-4 font-pixel text-sm tracking-[0.06em] text-glow-100">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class="witchlight block py-3 no-underline transition hover:text-violet-300"
            style={`animation-duration: ${l.duration}; animation-delay: ${l.delay};`}
          >
            {l.label}
          </a>
          {l.children && (
            <ul class="flex flex-col gap-1 border-l border-void-700/80 pl-4">
              {l.children.map((c) => (
                <li>
                  <a
                    href={c.href}
                    class="block py-2 text-xs text-mist-400 no-underline transition hover:text-violet-300"
                  >
                    {c.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.querySelector('[data-nav-toggle]');
  const menu = document.querySelector('[data-nav-menu]');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>

---
import { Image } from 'astro:assets';
import sealMercury from '../assets/brand/seal-mercury-glow.png';
const year = new Date().getFullYear();
---

<footer class="relative z-10 mt-24 border-t border-void-700/80 bg-void-900/60">
  <div class="mx-auto max-w-4xl px-6 py-16 text-center">
    <Image
      src={sealMercury}
      alt=""
      aria-hidden="true"
      loading="lazy"
      widths={[96, 192]}
      sizes="48px"
      class="mx-auto mb-8 w-12 opacity-80"
    />
    <p class="witchlight font-pixel text-lg tracking-[0.08em] text-glow-50">
      Alone in the Dungeon
    </p>
    <p class="mt-4 font-sans text-xs uppercase tracking-[0.22em] text-mist-500">
      A <a href="https://mattglbrt.com">Matt Gilbert</a> joint.
    </p>
    <p class="mt-3 font-sans text-xs tracking-[0.12em] text-mist-600">
      <a href="/contact/" class="hover:text-violet-300">Contact</a>
      <span class="mx-2 text-void-600">·</span>
      <a href="/rss.xml" class="hover:text-violet-300">RSS</a>
      <span class="mx-2 text-void-600">·</span>
      <a href="/privacy/" class="hover:text-violet-300">Privacy</a>
      <span class="mx-2 text-void-600">·</span>
      <a href="/terms/" class="hover:text-violet-300">Terms</a>
      <span class="mx-2 text-void-600">·</span>
      <a href="/disclaimer/" class="hover:text-violet-300">Disclaimer</a>
    </p>
    <p class="mt-2 font-sans text-xs tracking-[0.12em] text-mist-600">
      © {year} Alone in the Dungeon · All content and artwork is human made, no AI
    </p>
  </div>
</footer>

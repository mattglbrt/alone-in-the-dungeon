---
// Collapsed-by-default contents disclosure for long posts. Native
// <details> so it works everywhere with no JS and stays out of the way —
// especially on mobile. Only renders when there are enough headings to be
// worth a tap.
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}
const { headings } = Astro.props;

// h2/h3 only; deeper levels are noise in a jump list
const entries = headings.filter((h) => h.depth === 2 || h.depth === 3);
const MIN_ENTRIES = 3;
---

{entries.length >= MIN_ENTRIES && (
  <div class="mx-auto max-w-[var(--container-prose)] px-6 pt-8">
    <details class="group rounded border border-void-700 bg-void-900/50 px-5 py-4">
      <summary class="cursor-pointer list-none font-sans text-[0.62rem] uppercase tracking-[0.24em] text-violet-300 marker:content-none">
        <span class="mr-2 inline-block transition-transform group-open:rotate-90" aria-hidden="true">›</span>
        Contents
      </summary>
      <ol class="mt-3 flex flex-col gap-1.5 border-l border-void-700/80 pl-4">
        {entries.map((h) => (
          <li class={h.depth === 3 ? 'pl-4' : undefined}>
            <a
              href={`#${h.slug}`}
              class="font-reading text-sm text-glow-200/85 no-underline transition hover:text-violet-300"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </details>
  </div>
)}

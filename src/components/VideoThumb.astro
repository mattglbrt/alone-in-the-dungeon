---
// YouTube thumbnail with play-button overlay for video posts without a
// committed heroImage.
//
// The thumbnail URL is resolved at build time (maxresdefault when it
// exists, else hqdefault — see utils/youtube.ts) and optimized through
// Astro's image service: fetched once during the build, served as
// right-sized local WebP with immutable caching instead of the 1280px
// i.ytimg originals that PSI flagged as the mobile LCP bottleneck.
import { Image } from 'astro:assets';
import { resolveYoutubeThumbnail } from '../utils/youtube';

interface Props {
  youtubeId: string;
  title: string;
  eager?: boolean;
  fetchpriority?: 'high' | 'low' | 'auto';
  /** classes for the wrapping div (positioning/aspect) */
  class?: string;
  /** classes for the <img> itself */
  imgClass?: string;
  /** responsive sizes attribute; default matches PostCard's grid slots */
  sizes?: string;
}
const {
  youtubeId,
  title,
  eager = false,
  fetchpriority,
  class: className = 'relative overflow-hidden',
  imgClass = 'aspect-[5/3] w-full object-cover transition duration-500 group-hover:scale-[1.03]',
  sizes = '(min-width: 1024px) 32vw, (min-width: 768px) 46vw, 92vw',
} = Astro.props;

const thumbnail = await resolveYoutubeThumbnail(youtubeId);
---

<div class={className}>
  <Image
    src={thumbnail}
    alt={title}
    inferSize
    widths={[320, 480, 720, 960]}
    sizes={sizes}
    quality={60}
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={fetchpriority}
    class={imgClass}
  />
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-void-950/70 to-transparent"></div>
  <div class="absolute inset-0 flex items-center justify-center">
    <div class="flex h-12 w-12 items-center justify-center rounded-full bg-void-950/70 text-glow-50">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M8 5v14l11-7z"/>
      </svg>
    </div>
  </div>
</div>

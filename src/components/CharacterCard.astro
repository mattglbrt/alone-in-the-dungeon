---
/*
  A single character sheet, rendered as data rather than a photo of the sheet:
  the stats stay searchable (Pagefind indexes real text), legible on a phone,
  and cost nothing in page weight. Designed for Shadowdark-style six-stat
  characters but nothing here is system-specific — every field past `name`
  is optional, so a Kal Arath character with no class or gear still renders
  cleanly.
*/

interface Stats {
  str?: number;
  dex?: number;
  con?: number;
  int?: number;
  wis?: number;
  cha?: number;
}

interface Props {
  name: string;
  /* The archetype line — 'The Half-Orc', 'The Halfling'. Sits above the name
     as the eyebrow, since in a gauntlet the ancestry is what you remember. */
  title?: string;
  ancestry?: string;
  charClass?: string;
  level?: number | string;
  stats?: Stats;
  hp?: number;
  maxHp?: number;
  ac?: number;
  gear?: string[];
  talent?: string;
  /* Struck through and desaturated — a gauntlet leaves bodies behind. */
  dead?: boolean;
  /* How they died, shown in place of the HP bar when dead. */
  epitaph?: string;
}

const {
  name,
  title,
  ancestry,
  charClass,
  level,
  stats,
  hp,
  maxHp,
  ac,
  gear = [],
  talent,
  dead = false,
  epitaph,
} = Astro.props;

/* Shadowdark modifiers follow the standard (score - 10) / 2, rounded down. */
const mod = (score: number) => Math.floor((score - 10) / 2);
const fmtMod = (m: number) => (m >= 0 ? `+${m}` : `${m}`);

const STAT_ORDER = [
  ['STR', stats?.str],
  ['INT', stats?.int],
  ['DEX', stats?.dex],
  ['WIS', stats?.wis],
  ['CON', stats?.con],
  ['CHA', stats?.cha],
] as const;

const hasStats = STAT_ORDER.some(([, v]) => v != null);

/* The HP pip row reads at a glance in a way "4/7" doesn't. Capped at 12 so a
   high-level character doesn't wrap the row. */
const showPips = hp != null && maxHp != null && maxHp <= 12;

const subtitle = [ancestry, charClass].filter(Boolean).join(' · ');
---

<article
  class:list={[
    'rune-card flex flex-col p-5',
    dead && 'opacity-60 grayscale-[0.4]',
  ]}
>
  <header class="border-b border-violet-600/25 pb-3">
    <div class="flex items-baseline justify-between gap-3">
      {title && (
        <p class="font-sans text-[0.62rem] uppercase tracking-[0.2em] text-violet-300">
          {title}
        </p>
      )}
      {level != null && (
        <p class="shrink-0 font-sans text-[0.62rem] uppercase tracking-[0.2em] text-mist-600">
          Lvl {level}
        </p>
      )}
    </div>

    <h3
      class:list={[
        'mt-1 font-pixel text-xl text-glow-50',
        dead && 'line-through decoration-spark-500/70',
      ]}
    >
      {name}
    </h3>

    {subtitle && (
      <p class="mt-0.5 font-sans text-xs uppercase tracking-[0.14em] text-azure-400/80">
        {subtitle}
      </p>
    )}
  </header>

  {hasStats && (
    <dl class="mt-3 grid grid-cols-2 gap-x-4 gap-y-1.5 font-sans text-xs">
      {STAT_ORDER.map(([label, value]) =>
        value == null ? null : (
          <div class="flex items-baseline justify-between border-b border-void-700/60 pb-1">
            <dt class="uppercase tracking-[0.18em] text-mist-500">{label}</dt>
            <dd class="text-glow-100">
              {value}
              <span class="ml-1.5 text-violet-300/80">({fmtMod(mod(value))})</span>
            </dd>
          </div>
        )
      )}
    </dl>
  )}

  {(hp != null || ac != null) && (
    <div class="mt-3 flex items-center justify-between gap-4 font-sans text-xs">
      {hp != null && (
        <div class="flex items-center gap-2">
          <span class="uppercase tracking-[0.18em] text-mist-500">HP</span>
          {showPips && (
            <span class="flex gap-0.5" aria-hidden="true">
              {Array.from({ length: maxHp! }, (_, i) => (
                <span
                  class:list={[
                    'h-1.5 w-1.5 rounded-full',
                    i < hp! ? 'bg-violet-400' : 'bg-void-600',
                  ]}
                ></span>
              ))}
            </span>
          )}
          <span class="text-glow-100">{maxHp != null ? `${hp}/${maxHp}` : hp}</span>
        </div>
      )}
      {ac != null && (
        <div class="flex items-center gap-2">
          <span class="uppercase tracking-[0.18em] text-mist-500">AC</span>
          <span class="text-glow-100">{ac}</span>
        </div>
      )}
    </div>
  )}

  {(gear.length > 0 || talent) && (
    <div class="mt-3 space-y-1.5 border-t border-violet-600/25 pt-3 font-sans text-xs leading-relaxed">
      {gear.length > 0 && (
        <p>
          <span class="uppercase tracking-[0.18em] text-mist-500">Gear</span>
          <span class="ml-2 text-glow-200/90">{gear.join(' · ')}</span>
        </p>
      )}
      {talent && (
        <p>
          <span class="uppercase tracking-[0.18em] text-mist-500">Talent</span>
          <span class="ml-2 text-glow-200/90">{talent}</span>
        </p>
      )}
    </div>
  )}

  {dead && epitaph && (
    <p class="mt-3 border-t border-spark-500/30 pt-3 font-reading text-xs italic text-spark-400/90">
      {epitaph}
    </p>
  )}
</article>

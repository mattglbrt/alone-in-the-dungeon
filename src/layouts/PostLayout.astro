---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import OrnamentalDivider from '../components/OrnamentalDivider.astro';
import ReadingTime from '../components/ReadingTime.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import TableOfContents from '../components/TableOfContents.astro';
import type { MarkdownHeading } from 'astro';
import type { Post } from '../utils/collections';
import { resolveYoutubeThumbnail } from '../utils/youtube';
import {
  TYPE_LABELS,
  STORY_KIND_LABELS,
  GAME_TYPE_LABELS,
  FORMAT_LABELS,
  STATUS_LABELS,
  typeBasePath,
  tagToLabel,
  systemToSlug,
  formatDate,
  postUrl,
  getNarrativeVersions,
  getSeriesPosts,
} from '../utils/collections';

interface Props {
  post: Post;
  readingTime?: number;
  headings?: MarkdownHeading[];
}
const { post, readingTime, headings = [] } = Astro.props;
const { data } = post;

const typeLabel = data.storyKind ? STORY_KIND_LABELS[data.storyKind] : TYPE_LABELS[data.type];
const typePath = typeBasePath(data.type);

// Chapters dramatizing live-play sessions: fetch the source posts for cross-linking
const sourcePosts = data.sourceSessions?.length
  ? await getCollection('posts', (p) => data.sourceSessions!.includes(p.id))
  : [];

// Live-play posts: fetch any narrative chapters that dramatize this session
const narrativeVersions =
  data.type === 'live-play' ? await getNarrativeVersions(post.id) : [];

const youtubeThumbnail = data.youtubeId
  ? await resolveYoutubeThumbnail(data.youtubeId)
  : undefined;

const ogImage = data.heroImage ? data.heroImage.src : youtubeThumbnail;

// Fetch series entry for breadcrumb + metadata
const seriesEntry = data.series
  ? (await getCollection('series')).find((s) => s.id === data.series)
  : undefined;

// Prev/next within the series, in episode order
let prevPost: Post | undefined;
let nextPost: Post | undefined;
if (data.series) {
  const siblings = await getSeriesPosts(data.series);
  const idx = siblings.findIndex((p) => p.id === post.id);
  if (idx !== -1) {
    prevPost = siblings[idx - 1];
    nextPost = siblings[idx + 1];
  }
}

const episodeLabel = (p: Post, fallback: string) =>
  p.data.episode != null ? `Episode ${p.data.episode}` : fallback;

const structuredData: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': data.format === 'video' ? 'VideoObject' : 'BlogPosting',
  headline: data.title,
  description: data.description,
  datePublished: data.date.toISOString(),
  ...(data.updated && { dateModified: data.updated.toISOString() }),
  author: { '@type': 'Person', name: 'Alone in the Dungeon' },
};

const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://aloneinthedungeon.com/' },
    { '@type': 'ListItem', position: 2, name: typeLabel, item: `https://aloneinthedungeon.com${typePath}/` },
    ...(seriesEntry
      ? [{ '@type': 'ListItem', position: 3, name: seriesEntry.data.title, item: `https://aloneinthedungeon.com/series/${seriesEntry.id}/` }]
      : []),
    { '@type': 'ListItem', position: seriesEntry ? 4 : 3, name: data.title },
  ],
};
---

<BaseLayout
  title={data.title}
  description={data.description}
  ogType="article"
  image={ogImage}
  structuredData={[structuredData, breadcrumbData]}
>

  {/* data-pagefind-body scopes the search index to post content; pages
      without it (listings, about, etc.) are excluded automatically */}
  <article class="relative" data-pagefind-body>
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mx-auto max-w-3xl px-6 pt-8">
      <ol class="flex flex-wrap items-center justify-center gap-1.5 font-sans text-[0.62rem] uppercase tracking-[0.18em] text-mist-500">
        <li><a href="/" class="no-underline hover:text-violet-300 transition">Home</a></li>
        <li aria-hidden="true" class="text-void-600">›</li>
        <li><a href={`${typePath}/`} class="no-underline hover:text-violet-300 transition">{typeLabel}</a></li>
        {seriesEntry && (
          <>
            <li aria-hidden="true" class="text-void-600">›</li>
            <li><a href={`/series/${seriesEntry.id}/`} class="no-underline hover:text-violet-300 transition">{seriesEntry.data.title}</a></li>
          </>
        )}
        <li aria-hidden="true" class="text-void-600">›</li>
        <li class="text-glow-200/70 truncate max-w-[16rem]">{data.title}</li>
      </ol>
    </nav>

    <!-- Candlelit header -->
    <header class="mx-auto max-w-3xl px-6 pt-10 pb-10 text-center">
      <div class="mb-6 flex flex-wrap items-center justify-center gap-3 font-sans text-[0.62rem] uppercase tracking-[0.24em]">
        <span class="rounded-full border border-violet-600/50 px-3 py-1 text-violet-300">
          {typeLabel}
        </span>
        {data.gameType && (
          <span class="text-mist-500">{GAME_TYPE_LABELS[data.gameType]}</span>
        )}
        {data.format === 'video' && (
          <span class="text-azure-400/80">{FORMAT_LABELS[data.format]}</span>
        )}
        {data.episode != null && (
          <span class="text-mist-500">Episode {data.episode}</span>
        )}
      </div>

      <h1 class="font-pixel text-3xl leading-tight text-glow-50 md:text-4xl lg:text-5xl">
        {data.title}
      </h1>

      {data.system && (
        <p class="mt-5 font-sans text-sm uppercase tracking-[0.18em]">
          <a
            href={`/systems/${systemToSlug(data.system)}/`}
            class="text-azure-400/90 no-underline transition hover:text-violet-300"
          >
            {data.system}
          </a>
        </p>
      )}

      <p class="mx-auto mt-6 max-w-xl font-reading text-base italic text-glow-200/90 md:text-lg">
        {data.description}
      </p>

      <div class="mt-7 flex items-center justify-center gap-3 font-sans text-xs uppercase tracking-[0.18em] text-mist-500">
        <span>{formatDate(data.date)}</span>
        <span class="text-void-600">·</span>
        <ReadingTime minutes={readingTime} />
      </div>

      <OrnamentalDivider class="mx-auto mt-10 w-44 text-violet-500" />
    </header>

    {sourcePosts.length > 0 && (
      <div class="mx-auto max-w-[var(--container-prose)] px-6 mb-10">
        <div class="rounded border border-void-700 bg-void-900/50 px-6 py-5 text-center">
          <p class="font-sans text-[0.62rem] uppercase tracking-[0.24em] text-violet-300">
            Dramatizes
          </p>
          <div class="mt-2 flex flex-wrap justify-center gap-x-2 gap-y-1">
            {sourcePosts.map((s) => (
              <a
                href={postUrl(s)}
                class="font-pixel text-sm text-glow-50 no-underline hover:text-violet-300"
              >
                {s.data.title} →
              </a>
            ))}
          </div>
        </div>
      </div>
    )}

    {narrativeVersions.length > 0 && (
      <div class="mx-auto max-w-[var(--container-prose)] px-6 mb-10">
        <div class="rounded border border-void-700 bg-void-900/50 px-6 py-5 text-center">
          <p class="font-sans text-[0.62rem] uppercase tracking-[0.24em] text-violet-300">
            Narrative version{narrativeVersions.length > 1 ? 's' : ''} available
          </p>
          <div class="mt-2 flex flex-wrap justify-center gap-x-2 gap-y-1">
            {narrativeVersions.map((s) => (
              <a
                href={postUrl(s)}
                class="font-pixel text-sm text-glow-50 no-underline hover:text-violet-300"
              >
                {s.data.title} →
              </a>
            ))}
          </div>
        </div>
      </div>
    )}

    {(data.bookAuthor || data.bookYear || data.readingFormat) && (
      <div class="mx-auto max-w-[var(--container-prose)] px-6 mb-10">
        <dl class="rounded border border-void-700 bg-void-900/50 grid grid-cols-2 gap-x-6 gap-y-3 px-6 py-5 font-sans text-sm sm:grid-cols-3">
          {data.bookAuthor && (
            <>
              <dt class="text-[0.62rem] uppercase tracking-[0.18em] text-mist-500">Author</dt>
              <dd class="text-glow-100 sm:col-span-2">{data.bookAuthor}</dd>
            </>
          )}
          {data.bookYear && (
            <>
              <dt class="text-[0.62rem] uppercase tracking-[0.18em] text-mist-500">Published</dt>
              <dd class="text-glow-100 sm:col-span-2">{data.bookYear}</dd>
            </>
          )}
          {data.readingFormat && (
            <>
              <dt class="text-[0.62rem] uppercase tracking-[0.18em] text-mist-500">Format</dt>
              <dd class="text-glow-100 sm:col-span-2">
                {data.readingFormat.charAt(0).toUpperCase() + data.readingFormat.slice(1)}
                {data.narrator && <span class="text-mist-400"> · narrated by {data.narrator}</span>}
              </dd>
            </>
          )}
          {data.startedReading && (
            <>
              <dt class="text-[0.62rem] uppercase tracking-[0.18em] text-mist-500">Started</dt>
              <dd class="text-glow-100 sm:col-span-2">{data.startedReading.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</dd>
            </>
          )}
          {data.finishedReading && (
            <>
              <dt class="text-[0.62rem] uppercase tracking-[0.18em] text-mist-500">Finished</dt>
              <dd class="text-glow-100 sm:col-span-2">{data.finishedReading.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</dd>
            </>
          )}
        </dl>
      </div>
    )}

    {/* YouTube embed for video posts (click-to-play facade) */}
    {data.format === 'video' && data.youtubeId && youtubeThumbnail && (
      <div class="mx-auto max-w-4xl px-6 mb-10">
        <YouTubeEmbed
          youtubeId={data.youtubeId}
          title={data.title}
          thumbnail={youtubeThumbnail}
        />
      </div>
    )}

    {data.heroImage && data.format !== 'video' && (
      <div class="mx-auto max-w-4xl px-6">
        <div class="overflow-hidden rounded-md border border-void-700">
          <Image
            src={data.heroImage}
            alt={data.heroImageAlt ?? data.title}
            loading="eager"
            widths={[720, 1080, 1440]}
            sizes="(min-width: 1024px) 896px, 92vw"
            class="block h-auto w-full object-cover"
          />
        </div>
      </div>
    )}

    <TableOfContents headings={headings} />

    <!-- Body -->
    <div class="prose-body mx-auto max-w-[var(--container-prose)] px-6 py-14">
      <slot />
    </div>

    {data.tags.length > 0 && (
      <div class="mx-auto max-w-[var(--container-prose)] px-6 pb-10">
        <div class="flex flex-wrap gap-2">
          {data.tags.map((t) => (
            <a
              href={`/tags/${t}/`}
              class="rounded-full border border-void-700 px-3 py-1 font-sans text-xs tracking-[0.1em] text-mist-400 no-underline transition hover:border-violet-500/60 hover:text-violet-300"
            >
              {tagToLabel(t)}
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Prev/next within the series -->
    {(prevPost || nextPost) && (
      <nav aria-label="Series navigation" class="mx-auto max-w-[var(--container-prose)] px-6 pb-10">
        <div class="grid gap-4 sm:grid-cols-2">
          {prevPost ? (
            <a href={postUrl(prevPost)} class="rune-card group block p-5 no-underline">
              <p class="font-sans text-[0.62rem] uppercase tracking-[0.24em] text-mist-500">
                ← {episodeLabel(prevPost, 'Previous')}
              </p>
              <p class="mt-2 font-pixel text-base text-glow-50 transition group-hover:text-violet-300">
                {prevPost.data.title}
              </p>
            </a>
          ) : (
            <div class="hidden sm:block" aria-hidden="true"></div>
          )}
          {nextPost && (
            <a href={postUrl(nextPost)} class="rune-card group block p-5 no-underline sm:text-right">
              <p class="font-sans text-[0.62rem] uppercase tracking-[0.24em] text-mist-500">
                {episodeLabel(nextPost, 'Next')} →
              </p>
              <p class="mt-2 font-pixel text-base text-glow-50 transition group-hover:text-violet-300">
                {nextPost.data.title}
              </p>
            </a>
          )}
        </div>
      </nav>
    )}

    <!-- Series nav -->
    {seriesEntry && (
      <div class="mx-auto max-w-[var(--container-prose)] px-6 pb-10">
        <div class="rounded border border-void-700 bg-void-900/50 px-6 py-5">
          <p class="font-sans text-[0.62rem] uppercase tracking-[0.24em] text-violet-300">
            Part of the series
          </p>
          <p class="mt-1 font-pixel text-lg text-glow-50">{seriesEntry.data.title}</p>
          {seriesEntry.data.status && (
            <p class="mt-1 font-sans text-xs text-mist-500">
              {STATUS_LABELS[seriesEntry.data.status]}
            </p>
          )}
          <a
            href={`/series/${seriesEntry.id}/`}
            class="mt-3 inline-block font-pixel text-sm text-violet-300 no-underline hover:text-glow-50"
          >
            View all episodes →
          </a>
        </div>
      </div>
    )}

    <div class="mx-auto max-w-[var(--container-prose)] px-6 pb-10 text-center">
      <a href={`${typePath}/`} class="font-pixel text-sm text-violet-300 no-underline hover:text-glow-50">
        ← Back to {typeLabel}
      </a>
    </div>
  </article>
</BaseLayout>

---
import { render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { makePostStaticPaths } from '../../utils/collections';

export const getStaticPaths = makePostStaticPaths('guides');

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const readingTime = remarkPluginFrontmatter?.readingTime as number | undefined;
---

<PostLayout post={post} readingTime={readingTime}>
  <Content />
</PostLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import OrnamentalDivider from '../../components/OrnamentalDivider.astro';
import { getAllSystemsWithCount, getPostsBySystem } from '../../utils/collections';

export async function getStaticPaths() {
  const systems = await getAllSystemsWithCount();
  return systems.map((s) => ({
    params: { slug: s.slug },
    props: { name: s.name },
  }));
}

const { slug } = Astro.params;
const { name } = Astro.props;
const posts = await getPostsBySystem(slug!);

const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://aloneinthedungeon.com/' },
    { '@type': 'ListItem', position: 2, name: 'Game Systems', item: 'https://aloneinthedungeon.com/systems/' },
    { '@type': 'ListItem', position: 3, name },
  ],
};
---

<BaseLayout
  title={`${name} — Game System`}
  description={`Every live play, story, and review for ${name} on Alone in the Dungeon.`}
  structuredData={breadcrumbData}
>
  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="mx-auto max-w-3xl px-6 pt-8">
    <ol class="flex flex-wrap items-center justify-center gap-1.5 font-sans text-[0.62rem] uppercase tracking-[0.18em] text-mist-500">
      <li><a href="/" class="no-underline hover:text-violet-300 transition">Home</a></li>
      <li aria-hidden="true" class="text-void-600">›</li>
      <li><a href="/systems/" class="no-underline hover:text-violet-300 transition">Game Systems</a></li>
      <li aria-hidden="true" class="text-void-600">›</li>
      <li class="text-glow-200/70">{name}</li>
    </ol>
  </nav>

  <section class="relative mx-auto max-w-3xl px-6 pt-10 pb-10 text-center">
    <p class="font-sans text-[0.62rem] uppercase tracking-[0.32em] text-mist-500">Game System</p>
    <h1 class="mt-3 font-pixel text-4xl text-glow-50 md:text-5xl">{name}</h1>
    <p class="mt-4 font-sans text-sm text-mist-500">
      {posts.length} {posts.length === 1 ? 'post' : 'posts'}
    </p>
    <OrnamentalDivider class="mx-auto mt-10 w-44 text-violet-500" />
  </section>

  <section class="relative mx-auto max-w-6xl px-6 pb-24">
    <div class="grid gap-7 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((p, i) => <PostCard post={p} eager={i < 3} />)}
    </div>
  </section>
</BaseLayout>

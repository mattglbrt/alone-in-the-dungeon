---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OrnamentalDivider from '../../components/OrnamentalDivider.astro';
import { getAllSystemsWithCount } from '../../utils/collections';

const systems = await getAllSystemsWithCount();
---

<BaseLayout
  title="Game Systems"
  description="Browse everything by game system — every live play, story, and review for each game on Alone in the Dungeon."
>
  <section class="relative mx-auto max-w-3xl px-6 pt-20 pb-10 text-center">
    <h1 class="font-pixel text-4xl text-glow-50 md:text-5xl">Game Systems</h1>
    <p class="mx-auto mt-6 max-w-xl font-reading text-lg italic text-glow-200/90">
      Every game on the table — follow a system to find all its live plays,
      stories, and reviews in one place.
    </p>
    <OrnamentalDivider class="mx-auto mt-10 w-44 text-violet-500" />
  </section>

  {systems.length > 0 ? (
    <section class="relative mx-auto max-w-4xl px-6 pb-24">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {systems.map((s) => (
          <a
            href={`/systems/${s.slug}/`}
            class="rune-card group block p-6 text-center no-underline"
          >
            <h2 class="font-pixel text-2xl text-glow-50 transition group-hover:text-violet-300">
              {s.name}
            </h2>
            <p class="mt-3 font-sans text-[0.62rem] uppercase tracking-[0.2em] text-mist-500">
              {s.count} {s.count === 1 ? 'post' : 'posts'}
            </p>
          </a>
        ))}
      </div>
    </section>
  ) : (
    <section class="mx-auto max-w-2xl px-6 pb-24 text-center">
      <p class="font-reading text-lg italic text-glow-200/70">
        No systems yet. The shelf is still being stocked.
      </p>
    </section>
  )}
</BaseLayout>

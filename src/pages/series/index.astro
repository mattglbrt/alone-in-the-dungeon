---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OrnamentalDivider from '../../components/OrnamentalDivider.astro';
import { getAllSeries, TYPE_LABELS, STATUS_LABELS, GAME_TYPE_LABELS, formatDate } from '../../utils/collections';

const allSeries = await getAllSeries();
---

<BaseLayout
  title="Series"
  description="Every campaign, story collection, and ongoing series on Alone in the Dungeon."
>
  <section class="relative mx-auto max-w-3xl px-6 pt-20 pb-10 text-center">
    <h1 class="font-pixel text-4xl text-glow-50 md:text-5xl">Series</h1>
    <p class="mx-auto mt-6 max-w-xl font-reading text-lg italic text-glow-200/90">
      Every campaign, story collection, and ongoing series.
    </p>
    <OrnamentalDivider class="mx-auto mt-10 w-44 text-violet-500" />
  </section>

  {allSeries.length > 0 ? (
    <section class="relative mx-auto max-w-5xl px-6 pb-24">
      <div class="grid gap-6 md:grid-cols-2">
        {allSeries.map((s) => (
          <a
            href={`/series/${s.id}/`}
            class="rune-card group block p-6 no-underline"
          >
            <div class="mb-3 flex flex-wrap items-center gap-2 font-sans text-[0.62rem] uppercase tracking-[0.2em]">
              <span class="rounded-full border border-violet-600/50 px-2 py-0.5 text-violet-300">
                {TYPE_LABELS[s.data.type]}
              </span>
              {s.data.gameType && (
                <span class="text-mist-500">{GAME_TYPE_LABELS[s.data.gameType]}</span>
              )}
              {s.data.system && (
                <span class="text-azure-400/80">{s.data.system}</span>
              )}
              <span class="text-mist-600">{STATUS_LABELS[s.data.status]}</span>
            </div>
            <h2 class="font-pixel text-2xl text-glow-50 transition group-hover:text-violet-300">
              {s.data.title}
            </h2>
            <p class="mt-3 font-reading text-sm leading-relaxed text-glow-200/80 line-clamp-3">
              {s.data.description}
            </p>
            <p class="mt-4 font-sans text-[0.62rem] uppercase tracking-[0.2em] text-mist-600">
              Started {formatDate(s.data.startDate)}
            </p>
          </a>
        ))}
      </div>
    </section>
  ) : (
    <section class="mx-auto max-w-2xl px-6 pb-24 text-center">
      <p class="font-reading text-lg italic text-glow-200/70">
        No series yet. The campaigns are still being planned.
      </p>
    </section>
  )}
</BaseLayout>

---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import OrnamentalDivider from '../../components/OrnamentalDivider.astro';
import { getPostsByType, getSeriesByType, getSeriesPostCounts, seriesCountLabel, STATUS_LABELS, formatDate } from '../../utils/collections';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getPostsByType('live-play');
  return paginate(posts, { pageSize: 12 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const posts = page.data;
const isFirstPage = page.currentPage === 1;

const allSeries = await getSeriesByType('live-play');
const counts = await getSeriesPostCounts();
---

<BaseLayout
  title={isFirstPage ? 'Live Plays' : `Live Plays — Page ${page.currentPage}`}
  description="Actual plays and raw recordings of my gaming sessions. Start here if you want to see how a game actually plays or curious about my process."
>
  <section class="relative mx-auto max-w-3xl px-6 pt-20 pb-10 text-center">
    <h1 class="font-pixel text-4xl text-glow-50 md:text-5xl">Live Plays</h1>
    <p class="mx-auto mt-6 max-w-xl font-reading text-lg italic text-glow-200/90">
      Raw recordings and recaps from the table — solo wargames, tabletop RPGs, and everything
      in between. Nothing fudged. Nothing safe.
    </p>
    <OrnamentalDivider class="mx-auto mt-10 w-44 text-violet-500" />
  </section>

  {isFirstPage && allSeries.length > 0 && (
    <section class="relative mx-auto max-w-5xl px-6 pb-16">
      <h2 class="heading-rule-left mb-8 font-pixel text-xl text-glow-50">Campaigns</h2>
      <div class="grid gap-6 md:grid-cols-2">
        {allSeries.map((s) => (
          <a
            href={`/series/${s.id}/`}
            class="rune-card group block p-6 no-underline"
          >
            <div class="mb-3 flex flex-wrap items-center gap-2 font-sans text-[0.62rem] uppercase tracking-[0.2em]">
              {s.data.system && (
                <span class="text-azure-400/80">{s.data.system}</span>
              )}
              <span class="text-mist-500">{seriesCountLabel(s.data.type, counts.get(s.id) ?? 0)}</span>
              <span class="text-mist-500">{STATUS_LABELS[s.data.status]}</span>
              <span class="text-mist-600">From {formatDate(s.data.startDate)}</span>
            </div>
            <h3 class="font-pixel text-2xl text-glow-50 transition group-hover:text-violet-300">
              {s.data.title}
            </h3>
            <p class="mt-3 font-reading text-sm leading-relaxed text-glow-200/80 line-clamp-3">
              {s.data.description}
            </p>
            <p class="mt-4 font-pixel text-xs text-violet-300">
              View all episodes →
            </p>
          </a>
        ))}
      </div>
    </section>
  )}

  {posts.length > 0 ? (
    <section class="relative mx-auto max-w-6xl px-6 pb-24">
      {allSeries.length > 0 && (
        <h2 class="heading-rule-left mb-8 font-pixel text-xl text-glow-50">All Sessions</h2>
      )}
      <div class="grid gap-7 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((p, i) => <PostCard post={p} eager={i < 3} />)}
      </div>
      <Pagination page={page} />
    </section>
  ) : (
    <section class="mx-auto max-w-2xl px-6 pb-24 text-center">
      <p class="font-reading text-lg italic text-glow-200/70">
        No sessions recorded yet. The table is set.
      </p>
    </section>
  )}
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import OrnamentalDivider from '../components/OrnamentalDivider.astro';
---

<BaseLayout
  title="Terms of Use"
  description="Terms of use for Alone in the Dungeon."
>
  <section class="relative mx-auto max-w-3xl px-6 pt-20 pb-10 text-center">
    <h1 class="candleglow font-pixel text-4xl text-glow-50 md:text-5xl">Terms of Use</h1>
    <p class="mt-4 font-sans text-xs uppercase tracking-[0.22em] text-mist-500">Last updated: 1 July 2026</p>
    <OrnamentalDivider class="mx-auto mt-8 w-44 text-violet-500" />
  </section>

  <div class="prose-body mx-auto max-w-[var(--container-prose)] px-6 pb-16">
    <p>
      By accessing <strong>aloneinthedungeon.com</strong> you agree to these terms. If you do not agree, please do not use the site.
    </p>

    <h2>Content ownership</h2>
    <p>
      All original written content, artwork, photography, and video produced by Matt Gilbert and published on this site is copyright &copy; Matt Gilbert. All rights reserved. You may share links to individual posts freely. You may quote brief excerpts for commentary or review purposes with attribution. You may not reproduce articles, artwork, or videos in full without written permission.
    </p>
    <p>
      To request permission for reproduction or commercial use, contact <a href="mailto:matt@hobbinomicon.com">matt@hobbinomicon.com</a>.

---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import OrnamentalDivider from '../components/OrnamentalDivider.astro';
import { getPublishedPosts, getFeaturedPost, postUrl } from '../utils/collections';

const posts = await getPublishedPosts();
const featured = await getFeaturedPost(posts);
const rest = posts.filter((p) => p.id !== featured?.id).slice(0, 6);

// maxresdefault is the true 16:9 frame; hqdefault/sddefault are 4:3 and
// letterbox 16:9 videos with black bars. maxresdefault 404s for videos
// that were never processed at high resolution, so fall back on error.
const featuredIsVideo = featured?.data.format === 'video';
const featuredYoutubeThumbnail =
  featuredIsVideo && featured?.data.youtubeId
    ? `https://i.ytimg.com/vi/${featured.data.youtubeId}/maxresdefault.jpg`
    : null;
const featuredYoutubeThumbnailFallback =
  featuredIsVideo && featured?.data.youtubeId
    ? `https://i.ytimg.com/vi/${featured.data.youtubeId}/hqdefault.jpg`
    : null;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Alone in the Dungeon',
  url: 'https://aloneinthedungeon.com',
  description: 'A blog about solo wargames and tabletop RPGs — live plays, reviews, stories, and hobby content.',
  author: {
    '@type': 'Person',
    name: 'Matt Gilbert',
    url: 'https://mattglbrt.com',
  },
};
---

<BaseLayout structuredData={websiteSchema}>
  <!-- Candlelit hero -->
  <section class="relative mx-auto flex min-h-[68vh] max-w-4xl flex-col items-center justify-center px-6 py-24 text-center">
    <h1 class="font-pixel text-5xl leading-tight text-glow-50 md:text-7xl">
      Alone in the Dungeon
    </h1>

    <p class="mt-10 max-w-xl font-reading text-lg italic text-glow-200/90 md:text-xl">
      A man, his basement, some dice, and a whole lot of solo roleplaying and wargaming.
    </p>

    <OrnamentalDivider class="mt-12 w-52 text-violet-500" />

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4 font-pixel text-sm">
      <a
        href="/live-plays/"
        class="witchlight rounded border border-violet-500/60 px-5 py-2.5 text-glow-50 no-underline transition hover:border-violet-400 hover:bg-violet-500/10"
      >
        Read the posts
      </a>
      <a
        href="/about/"
        class="px-2 py-2.5 text-violet-300 no-underline transition hover:text-glow-50"
      >
        What is this?
      </a>
    </div>
  </section>

  {featured && (
    <section class="relative mx-auto max-w-5xl px-6 pb-20">
      <p class="mb-6 text-center font-sans text-[0.65rem] uppercase tracking-[0.32em] text-mist-500">
        Latest
      </p>

      <a href={postUrl(featured)} class="rune-card group block overflow-hidden no-underline">
        <div class="grid md:grid-cols-2">
          {featured.data.heroImage ? (
            <div class="relative aspect-[5/3] overflow-hidden md:aspect-auto">
              <Image
                src={featured.data.heroImage}
                alt={featured.data.heroImageAlt ?? featured.data.title}
                loading="eager"
                widths={[480, 720, 960]}
                sizes="(min-width: 768px) 48vw, 92vw"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
              />
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-void-950/70 to-transparent"></div>
              {featuredIsVideo && (
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="flex h-12 w-12 items-center justify-center rounded-full bg-void-950/70 text-glow-50">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>
              )}
            </div>
          ) : featuredYoutubeThumbnail ? (
            <div class="relative aspect-[5/3] overflow-hidden md:aspect-auto">
              <img
                src={featuredYoutubeThumbnail}
                alt={featured.data.title}
                loading="lazy"
                onerror={`this.onerror=null;this.src='${featuredYoutubeThumbnailFallback}'`}
                class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
              />
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-void-950/70 to-transparent"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-void-950/70 text-glow-50">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
            </div>
          ) : (
            <div class="flex min-h-[200px] items-center justify-center bg-void-800/50 md:min-h-[260px]">
              <span class="px-8 text-center font-pixel text-xl text-violet-300/90 md:text-2xl">
                {featured.data.title}
              </span>
            </div>
          )}
          <div class="flex flex-col justify-center p-8">
            <p class="font-sans text-[0.62rem] uppercase tracking-[0.24em] text-violet-300">
              Featured
            </p>
            <h2 class="mt-3 font-pixel text-3xl text-glow-50 transition group-hover:text-violet-300">
              {featured.data.title}
            </h2>
            <p class="mt-4 font-reading text-base italic text-glow-200/85">
              {featured.data.description}
            </p>
          </div>
        </div>
      </a>
    </section>
  )}

  {rest.length > 0 && (
    <section class="relative mx-auto max-w-6xl px-6 pb-24">
      <div class="mb-8 flex items-end justify-between">
        <h2 class="heading-rule-left font-pixel text-2xl text-glow-50">
          From the dungeon
        </h2>
        <a href="/live-plays/" class="font-pixel text-sm text-violet-300 no-underline hover:text-glow-50">
          All posts →
        </a>
      </div>

      <div class="grid gap-7 md:grid-cols-2 lg:grid-cols-3">
        {rest.map((p, i) => <PostCard post={p} eager={i < 3} />)}
      </div>
    </section>
  )}

  {posts.length === 0 && (
    <section class="mx-auto max-w-2xl px-6 pb-24 text-center">
      <OrnamentalDivider class="mx-auto mb-8 w-40 text-violet-500" />
      <p class="font-reading text-lg italic text-glow-200/80">
        The campfire is lit, but no tales have been told yet. Drop a post into
        <code class="font-pixel text-azure-300">src/content/posts/</code> to begin.
      </p>
    </section>
  )}
</BaseLayout>
